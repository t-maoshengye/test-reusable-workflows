name: Call a reusable workflow

on:
  push:
    branches:
      - dev
  workflow_dispatch:
    inputs:
      username:
        required: true
        type: string

jobs:
  call-workflow:
    uses: t-maoshengye/test-reusable-workflows/.github/workflows/reusable_workflow.yml@dev

  call-workflow-passing-data:
    uses: t-maoshengye/test-reusable-workflows/.github/workflows/reusable_workflow.yml@dev
    with:
      username: ye
